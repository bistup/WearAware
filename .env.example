# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Google Cloud Vision API
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ---- Backend env vars (set on Proxmox server in /opt/wearaware/backend/.env) ----

# Google API Key (used for both Cloud Vision and Vertex AI grounded search)
# The same key powers OCR label scanning and sustainable product web search
# GOOGLE_API_KEY=your_google_api_key_here

# eBay Browse API (for second-hand clothing search)
# 1. Create an app at https://developer.ebay.com/my/keys
# 2. Copy the Production App ID (Client ID) and Cert ID (Client Secret)
# EBAY_APP_ID=your_ebay_client_id_here
# EBAY_CERT_ID=your_ebay_client_secret_here
# EBAY_ENV=production
