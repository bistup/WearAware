    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "babel-preset-expo": "~12.0.1",
    "jest": "^30.3.0",
    "react-native-dotenv": "^3.4.11"
  },
  "private": true,
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@env$": "<rootDir>/__mocks__/@env.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/utils/impactCalculator.js"
    ]
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --verbose",
    "test:coverage": "jest --verbose --coverage"
  }
